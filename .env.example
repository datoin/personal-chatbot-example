# ──────────────────────────────────────────────
# AI Chatbot — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required — API key for your LLM provider
OPENAI_API_KEY=sk-your-api-key-here

# Optional — Base URL of the OpenAI-compatible API
# Default: https://api.openai.com/v1
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional — Model identifier
# Default: gpt-4o
# Examples:
#   OpenAI:      gpt-4o, gpt-4o-mini
#   OpenRouter:  google/gemma-4-31b-it:free, openai/gpt-4o
#   Ollama:      llama3, mistral
OPENAI_MODEL=gpt-4o

# Optional — System prompt that defines the assistant's personality
SYSTEM_PROMPT="You are a helpful assistant."
